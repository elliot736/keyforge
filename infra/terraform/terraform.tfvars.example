aws_region     = "us-east-1"
environment    = "prod"
project        = "keyforge"
domain         = ""  # Set to your domain for HTTPS

# Compute sizing
db_instance_class       = "db.t4g.micro"
redis_node_type         = "cache.t4g.micro"
api_cpu                 = 512
api_memory              = 1024
api_desired_count       = 2
dashboard_cpu           = 256
dashboard_memory        = 512
dashboard_desired_count = 2

enable_deletion_protection = true
