{
  "name": "@keyforge/shared",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.mjs", "require": "./dist/index.js" },
    "./schemas": { "types": "./dist/schemas/index.d.ts", "import": "./dist/schemas/index.mjs", "require": "./dist/schemas/index.js" },
    "./constants": { "types": "./dist/constants/index.d.ts", "import": "./dist/constants/index.mjs", "require": "./dist/constants/index.js" },
    "./utils": { "types": "./dist/utils/index.d.ts", "import": "./dist/utils/index.mjs", "require": "./dist/utils/index.js" }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
